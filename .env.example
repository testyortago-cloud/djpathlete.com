# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=

# GoHighLevel
GHL_API_KEY=
GHL_LOCATION_ID=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Firebase (Storage, Firestore, AI Functions)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_SERVICE_ACCOUNT_KEY=

# Google Analytics (gtag.js) — optional, tag is skipped if unset
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# GA4 Data API (server-side reporting in /admin/ads/ga4-overview)
# 1. Cloud Console → APIs & Services → enable "Google Analytics Data API"
# 2. IAM → Service Accounts → create one → Keys → Add key → JSON → download
# 3. GA4 → Admin → Property access management → add the service-account email
#    as Viewer on the property (no roles needed in GCP)
# 4. Set GA4_PROPERTY_ID to the numeric property ID (Admin → Property settings)
# 5. Set GA4_SERVICE_ACCOUNT_JSON to either the raw JSON key (multi-line) OR
#    its base64 encoding (single-line, recommended for Vercel envs):
#      base64 -w0 service-account.json
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON=

# Firebase Functions secrets (set via: firebase functions:secrets:set <NAME>)
# ANTHROPIC_API_KEY — same as above, set in Firebase
# SUPABASE_URL — same as NEXT_PUBLIC_SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY — same as above
# RESEND_API_KEY — same as above
# TAVILY_API_KEY — web research for blog/social generation (Phase 4)
# ASSEMBLYAI_API_KEY — video transcription (Phase 3)
# META_APP_SECRET — Facebook + Instagram OAuth (Phase 2)
# TIKTOK_APP_SECRET — TikTok Content Posting API (Phase 2)
# YOUTUBE_CLIENT_SECRET — YouTube Data API OAuth (Phase 2)
# LINKEDIN_CLIENT_SECRET — LinkedIn Marketing API (Phase 2)
# APP_URL — public URL of the Next.js app, used by scheduled Functions to
#   call back into /api/admin/internal/* routes (e.g., analytics sync, Phase 5a)
# INTERNAL_CRON_TOKEN — same value as the Vercel env var below; Firebase
#   Functions include it as a Bearer token when calling /api/admin/internal/*

# ---- Starter AI Automation (Phase 1-6) ----
# Public-ish values live in Vercel env. Secrets stay in Firebase secret manager (above).

# Platform OAuth client IDs (public-ish — safe for Vercel env)
META_APP_ID=
TIKTOK_APP_ID=
YOUTUBE_CLIENT_ID=
LINKEDIN_CLIENT_ID=

# Platform OAuth client secrets (sensitive — Vercel env, encrypted)
YOUTUBE_CLIENT_SECRET=
META_APP_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
LINKEDIN_CLIENT_SECRET=

# Printful
PRINTFUL_API_KEY=
PRINTFUL_WEBHOOK_SECRET=
PRINTFUL_STORE_ID=

# Content Studio (Starter AI Automation Phase 1)
# Enables the new Content Studio admin surface (unified videos/social/calendar).
# When 'true', /admin/videos, /admin/social, /admin/calendar redirect into
# /admin/content, and the sidebar shows a single "Content Studio" entry.
CONTENT_STUDIO_ENABLED=false

# Shop
SHOP_ENABLED=false

# ---- Shop Phase 2 ----
AMAZON_ASSOCIATES_TAG=djp-20
FIREBASE_PRIVATE_BUCKET=djp-athlete-downloads
RESEND_AUDIENCE_ID=
SHOP_DIGITAL_ENABLED=false
SHOP_AFFILIATE_ENABLED=false

# ---- Automation orchestration (Phase 5 + 6) ----
# Shared bearer secret used by:
#   - Vercel Cron  → /api/admin/internal/publish-due
#   - Firebase onSchedule functions → Next.js /api/admin/internal/* routes
#   - Firebase runJob (HTTPS) for admin-triggered "Run now" buttons
# Generate with: openssl rand -hex 32
# Same value must be set in Vercel env AND Firebase Functions secrets:
#   firebase functions:secrets:set INTERNAL_CRON_TOKEN
INTERNAL_CRON_TOKEN=

# Public Next.js URL. Firebase Functions POST back here to render email
# previews / compute metrics. Also set as Firebase secret named APP_URL.
#   firebase functions:secrets:set APP_URL
# (Next.js server-side code reads NEXTAUTH_URL; APP_URL is Firebase-side only.)

# Recipient for:
#   - TikTok hybrid publish notifications (Phase 3)
#   - Weekly Content Report email (Phase 5c)
#   - Daily Pulse email (Phase 5d)
# Typically the coach's primary inbox.
COACH_EMAIL=

# Firebase project identifiers for the admin /admin/automation "Run now"
# button. The dispatcher builds the Firebase runJob URL as:
#   https://<region>-<project>.cloudfunctions.net/runJob
# Falls back to NEXT_PUBLIC_FIREBASE_PROJECT_ID + us-central1 if unset.
FIREBASE_PROJECT_ID=
FIREBASE_FUNCTIONS_REGION=us-central1
# Optional full URL override (e.g., if you remap the function behind a custom domain):
# FIREBASE_RUN_JOB_URL=https://automation.darrenjpaul.com/runJob

# Google Ads — Phase 1.1 (OAuth + nightly sync)
# Apply for the Developer Token via Google Ads → Tools & Settings → API Center (1–2 wk approval).
# Engineering builds against a Google Ads test account first; flip to live by swapping this value.
GOOGLE_ADS_DEVELOPER_TOKEN=
# OAuth credentials from Google Cloud Console (APIs & Services → Credentials → OAuth client ID, Web application).
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
# 10-digit Customer ID, no dashes. If using an MCC, set this to the manager Customer ID.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Must match the redirect URI configured in Google Cloud Console exactly.
# Production:  https://www.darrenjpaul.com/api/integrations/google-ads/callback
# Local dev:   http://localhost:3050/api/integrations/google-ads/callback
GOOGLE_ADS_REDIRECT_URI=
